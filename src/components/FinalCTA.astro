<section id="booking" class="stage stage--soft" aria-label="Booking CTA">
    <div class="blob blob--orange pos-tr" aria-hidden="true"></div>
    <div class="blob blob--peach pos-br" aria-hidden="true"></div>

    <div class="dots" aria-hidden="true">
        <span class="dot gray" style="top: 18%; left: 18%"></span>
        <span class="dot peach lg" style="top: 30%; right: 22%"></span>
        <span class="dot orange sm" style="bottom: 26%; left: 14%"></span>
    </div>

    <div class="container stage-inner">
        <div class="cta-panel">
            <div class="cta-copy">
                <h3 class="h2">開始建立更安心的照顧安排</h3>
                <p class="p">
                    立即預約服務，讓每一次照顧，都可理解、可追溯、可被信任。
                </p>

                <div class="cta-row" style="margin-top: 16px;">
                    <a
                        class="btn btn-primary"
                        href="https://example.com/booking"
                        target="_blank"
                        rel="noreferrer"
                    >
                        立即下載
                    </a>
                </div>

                <div class="cta-trust">
                    <span class="pill">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path
                                d="M7 7h10v10H7V7Z"
                                stroke="currentColor"
                                stroke-width="2"></path>
                            <path
                                d="M9 3h6"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                            <path
                                d="M9 21h6"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                        </svg>
                        短片 + 文字回報
                    </span>

                    <span class="pill">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path
                                d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11Z"
                                stroke="currentColor"
                                stroke-width="2"></path>
                            <path
                                d="M12 11.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"
                                stroke="currentColor"
                                stroke-width="2"></path>
                        </svg>
                        狀態重點可追溯
                    </span>

                    <span class="pill">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path
                                d="M4 12l3 3 7-7"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                            <path
                                d="M12 22c5 0 9-4 9-9S17 4 12 4 3 8 3 13s4 9 9 9Z"
                                stroke="currentColor"
                                stroke-width="2"></path>
                        </svg>
                        流程化執行
                    </span>
                </div>
            </div>

            <div class="cta-visual" aria-hidden="true">
                <div class="cta-card float">
                    <div class="cta-card-title">Booking Preview</div>
                    <div class="cta-card-line"></div>
                    <div class="cta-card-row">
                        <span class="cta-dot"></span>
                        <span class="cta-card-text">選擇日期與時段</span>
                    </div>
                    <div class="cta-card-row">
                        <span class="cta-dot cta-dot--peach"></span>
                        <span class="cta-card-text">填寫寵物狀態重點</span>
                    </div>
                    <div class="cta-card-row">
                        <span class="cta-dot cta-dot--gray"></span>
                        <span class="cta-card-text">確認服務與地址</span>
                    </div>

                    <div class="cta-card-btn">確認預約</div>
                </div>
            </div>
        </div>
    </div>
</section>
