<section id="audience" class="stage stage--alt" aria-label="Audience">
    <div class="blob blob--peach pos-tr" aria-hidden="true"></div>
    <div class="blob blob--cream pos-bl" aria-hidden="true"></div>

    <div class="dots" aria-hidden="true">
        <span class="dot orange lg" style="top: 14%; left: 10%"></span>
        <span class="dot peach" style="top: 22%; right: 18%"></span>
        <span class="dot gray sm" style="bottom: 18%; left: 22%"></span>
        <span class="dot orange sm" style="bottom: 26%; right: 30%"></span>
    </div>

    <div class="container stage-inner">
        <div class="split">
            <div class="section-left">
                <div class="section-head section-head--stack">
                    <h3>🐾 適合對象</h3>
                    <div class="hint">把「安心」變成可持續的日常</div>
                </div>

                <div class="audience-list">
                    <div class="aud-item">
                        <div class="aud-icon" aria-hidden="true">⚡️</div>
                        <div class="aud-text">
                            <div class="aud-title">工作繁忙人士</div>
                            <div class="aud-desc">
                                需要穩定照顧安排，且希望過程看得見、追得到。
                            </div>
                        </div>
                    </div>

                    <div class="aud-item">
                        <div class="aud-icon" aria-hidden="true">🧳</div>
                        <div class="aud-text">
                            <div class="aud-title">經常外出人士</div>
                            <div class="aud-desc">
                                短期出差、旅行、假期安排，也能掌握寵物狀態。
                            </div>
                        </div>
                    </div>

                    <div class="aud-item">
                        <div class="aud-icon" aria-hidden="true">🏠</div>
                        <div class="aud-text">
                            <div class="aud-title">需要穩定照顧安排的家庭</div>
                            <div class="aud-desc">
                                讓照顧不靠運氣，而靠流程與紀錄。
                            </div>
                        </div>
                    </div>

                    <div class="aud-item">
                        <div class="aud-icon" aria-hidden="true">🔍</div>
                        <div class="aud-text">
                            <div class="aud-title">重視信任與細節的主人</div>
                            <div class="aud-desc">
                                在意照顧品質、互動細節與服務一致性。
                            </div>
                        </div>
                    </div>
                </div>

                <div class="audience-note">
                    <span class="pill">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path
                                d="M12 2l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V6l7-4Z"
                                stroke="currentColor"
                                stroke-width="2"></path>
                            <path
                                d="M8.5 12l2.2 2.2L15.5 9.6"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                        </svg>
                        流程一致，才會安心
                    </span>
                    <span class="pill">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path
                                d="M4 6h16M4 12h16M4 18h16"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"></path>
                        </svg>
                        每次都有紀錄可追溯
                    </span>
                </div>
            </div>

            <div class="section-right">
                <div class="aud-visual">
                    <div
                        class="aud-card aud-card--big float"
                        aria-hidden="true"
                    >
                        <div class="aud-card-top">
                            <div class="aud-badge">Today</div>
                            <div class="aud-chip">STATUS</div>
                        </div>
                        <div class="aud-card-row">
                            <div class="aud-avatar">
                                <img
                                    src="https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&w=240&q=70"
                                    alt=""
                                />
                            </div>
                            <div class="aud-card-main">
                                <div class="aud-card-title">Buddy</div>
                                <div class="aud-card-sub">
                                    Walk + water refill
                                </div>
                            </div>
                        </div>
                        <div class="aud-progress">
                            <span class="aud-bar"></span>
                        </div>
                    </div>

                    <div
                        class="aud-card aud-card--mid float"
                        style="animation-delay: .8s"
                        aria-hidden="true"
                    >
                        <div class="aud-mini">
                            <div class="aud-mini-dot"></div>
                            <div class="aud-mini-text">短片紀錄已上傳</div>
                        </div>
                    </div>

                    <div
                        class="aud-card aud-card--small float"
                        style="animation-delay: 1.4s"
                        aria-hidden="true"
                    >
                        <div class="aud-mini">
                            <div class="aud-mini-dot aud-mini-dot--peach"></div>
                            <div class="aud-mini-text">服務報告已完成</div>
                        </div>
                    </div>

                    <div
                        class="aud-photo float"
                        style="animation-delay: 1.1s"
                        aria-hidden="true"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&w=720&q=70"
                            alt=""
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="stage-divider" aria-hidden="true"></div>
</section>
