---
interface Props {
    brand: string;
}
const { brand } = Astro.props;
---

<header class="nav nav--new">
    <div class="container nav-inner">
        <!-- Logo -->
        <a class="brand" href="#top" aria-label="Go to top">
            <img src="/images/halopetlogo.png" alt={brand} class="brand-logo" />
        </a>

        <!-- Navigation -->
        <nav class="nav-links" aria-label="Primary">
            <a href="#positioning">品牌定位</a>
            <a href="#services">核心服務</a>
            <a href="#magic">Magic Moment</a>
            <a href="#booking" class="btn btn-primary btn--nav"> 立即下載 </a>
        </nav>
    </div>
</header>
